# Copy to .env.local and fill in actual values. Never commit the real .env.local.
# Production values are managed in Vercel env — this file is the canonical list.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL (rarely used — pooler DNS blocked from some networks)
DATABASE_URL=

# --- Site ---
NEXT_PUBLIC_APP_URL=https://hotel.unccdcop17.org
NEXT_PUBLIC_SUPPORT_EMAIL=hotel@unccdcop17.org

# --- Encryption / guest-portal ---
# 32-byte hex: openssl rand -hex 32
ENCRYPTION_KEY=
# 32-byte hex: openssl rand -hex 32 — MUST be different from ENCRYPTION_KEY
BOOKING_ACCESS_TOKEN_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="COP17 Mongolia <noreply@hotel.unccdcop17.org>"

# --- Maps (public — MUST be domain-restricted in GCP console) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Payments (Golomt Bank) ---
# "live" required in production; "mock" only permitted in dev/staging
GOLOMT_MODE=live
GOLOMT_MERCHANT_ID=
GOLOMT_SECRET_TOKEN=
GOLOMT_CALLBACK_SECRET=
GOLOMT_CHECKOUT_URL=
GOLOMT_STATUS_URL=

# --- Optional: Sentry (see docs/OBSERVABILITY.md) ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
